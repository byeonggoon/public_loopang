# ── 수집기 (collector) ──────────────────────────────
# 네이버 개발자센터(https://developers.naver.com) 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 공공데이터포털(https://data.go.kr) 마이페이지 인증키 (decoding 키 권장)
DATA_GO_KR_KEY=
# 사용할 데이터셋의 OpenAPI 엔드포인트(.../getList). 미설정 시 data.go.kr 소스 건너뜀
DATA_GO_KR_ENDPOINT=
# (선택) 가져올 행 수
DATA_GO_KR_ROWS=100

# (선택) BTIS 최근 몇 페이지를 수집할지 (1페이지 = 약 10건). 기본 5
BTIS_MAX_PAGES=5
# (선택) NABO(국회예산정책처) 공무국외출장 보고서 페이지 수. 기본 20 (키 불필요)
NABO_MAX_PAGES=20
# (선택) 선관위(중앙선거관리위원회) 보고서 페이지 수. 기본 10 (키 불필요)
NEC_MAX_PAGES=10
# (선택) 방통위(방송통신위원회) 국외출장보고서 페이지 수. 기본 15 (키 불필요)
KCC_MAX_PAGES=15

# Supabase — 수집기는 service_role 키 사용 (RLS 우회, 절대 클라이언트 노출 금지)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── 웹 (web/.env.local) ─────────────────────────────
# 아래 두 개는 web/.env.local 에 넣으세요 (public 키 = 읽기 전용)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
